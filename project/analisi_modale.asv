function s = analisi_modale(s)

[Vs,D] = eig(s.K,s.M);
lambda = diag(D);
omega = sqrt(lambda);
freqs = omega/(2*pi);
s.freq=freqs;
s.V=Vs;
vs='Quante frequenze vuoi stampare?';
ancora=1;
xmax=100;
xmin=1;
xdef=10;
while ancora
    n=query_integer_d(vs,xmin,xmax,xdef);
    ancora=0;
end

stit=sprintf('Prime %d Frequenze Proprie',n);
for i=1:n
    str=sprintf('%d Freq Propria: %f', i, )


end